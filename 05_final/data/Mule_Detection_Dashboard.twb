          <datasource-dependencies datasource='federated.acc'>
            <column caption='Account ID' datatype='string' name='[Account_ID]' role='dimension' type='nominal' />
            <column caption='Risk Level' datatype='string' name='[Risk_Level]' role='dimension' type='nominal' />
            <column-instance column='[Account_ID]' derivation='Count' name='[cnt:Account_ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Risk_Level]' derivation='None' name='[none:Risk_Level:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.acc].[none:Risk_Level:nk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.acc].[cnt:Account_ID:qk]</rows>
        <cols>[federated.acc].[none:Risk_Level:nk]</cols>
      </table>
      <simple-id uuid='{77777777-7777-7777-7777-777777777777}' />
    </worksheet>
    <worksheet name='8. Top Risky Accounts'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='14'>Top Risky Accounts</run>
            <run>Æ&#10;</run>
            <run fontsize='10'>เรียงตาม Risk Score — สูงสุดคือบัญชีที่ควรระงับทันที</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Account Summary' name='federated.acc' />
          </datasources>
          <datasource-dependencies datasource='federated.acc'>
            <column caption='Account ID' datatype='string' name='[Account_ID]' role='dimension' type='nominal' />
            <column caption='Layer' datatype='string' name='[Layer]' role='dimension' type='nominal' />
            <column caption='Risk Score' datatype='integer' name='[Risk_Score]' role='measure' type='quantitative' />
            <column-instance column='[Account_ID]' derivation='Count' name='[cnt:Account_ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Layer]' derivation='None' name='[none:Layer:nk]' pivot='key' type='nominal' />
            <column-instance column='[Risk_Score]' derivation='Sum' name='[sum:Risk_Score:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.acc].[none:Layer:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:Layer:nk]' member='&quot;Layer1&quot;' />
              <groupfilter function='member' level='[none:Layer:nk]' member='&quot;Layer2&quot;' />
              <groupfilter function='member' level='[none:Layer:nk]' member='&quot;Layer3+&quot;' />
            </groupfilter>
          </filter>
          <filter class='quantitative' column='[federated.acc].[sum:Risk_Score:qk]' included-values='non-null' />
          <slices>
            <column>[federated.acc].[sum:Risk_Score:qk]</column>
            <column>[federated.acc].[none:Layer:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.acc].[none:Layer:nk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.acc].[cnt:Account_ID:qk]</rows>
        <cols>[federated.acc].[sum:Risk_Score:qk]</cols>
      </table>
      <simple-id uuid='{88888888-8888-8888-8888-888888888888}' />
    </worksheet>
